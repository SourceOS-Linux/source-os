# enroll.nix — device-specific settings generated by scripts/enroll.sh.
#
# This file (enroll.nix) is gitignored and never committed.
# enroll.nix.example shows the expected structure.
#
# To generate: sudo bash scripts/enroll.sh
# To regenerate keys only: sudo bash scripts/enroll.sh --keys-only (future)
#
# Generated values:
#   signingPublicKey  — minisign public key for Nix cache manifest verification
#   trusted-public-keys — harmonia ed25519 cache signing key for this device
#
{ ... }:
{
  # minisign public key for nix-cache-info signature verification.
  # Corresponds to /etc/sourceos/nix-cache.{pub,sec}.
  sourceos.syncd.signingPublicKey = "RWS...";

  # harmonia binary cache signing key for this device.
  # Corresponds to /etc/sourceos/harmonia-signing.{key,pub}.
  # Appended to the base list in default.nix.
  nix.settings.trusted-public-keys = [
    "builder-aarch64-1:AAAA..."
  ];
}
