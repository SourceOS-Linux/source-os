# Device-specific NixOS hardware config — generated by scripts/enroll.sh.
# Never committed; each M2 generates its own via nixos-generate-config.
hosts/**/hardware-configuration.nix

# Device-specific enrollment settings — generated by scripts/enroll.sh.
# Contains signingPublicKey and harmonia trusted-public-key for this device.
# See hosts/builder-aarch64/enroll.nix.example for structure.
hosts/**/enroll.nix

# SOPS plaintext secrets live at /etc/sourceos/secrets.yaml (outside the repo).
# This catches accidental staging of a plaintext secrets file.
hosts/**/secrets.yaml

# Build artifacts (binaries live in GCS, not git)
artifacts/
